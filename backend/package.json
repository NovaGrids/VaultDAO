{
  "name": "@vaultdao/backend",
  "version": "0.1.0",
  "description": "VaultDAO backend service exposing version and build metadata",
  "private": true,
  "type": "module",
  "build": {
    "channel": "stable",
    "updatedAt": "2026-03-25T13:35:46Z"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-timeout=30000 $(find src -name '*.test.ts' | sort | tr '\\n' ' ')",
    "lint": "npm run typecheck",
    "start": "node dist/index.js",
    "replay": "tsx src/modules/events/replay/replay-cli.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.2.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.35.0",
    "@opentelemetry/instrumentation-express": "^0.35.0",
    "@opentelemetry/instrumentation-http": "^0.35.0",
    "@opentelemetry/sdk-node": "^0.35.0",
    "express": "^5.1.0",
    "ioredis": "5.6.1",
    "prom-client": "^14.0.0",
    "stellar-sdk": "^11.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "fast-check": "^4.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
